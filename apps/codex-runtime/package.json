{
  "name": "codex-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc --noEmit",
    "dev": "node ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "lint": "node ./node_modules/@biomejs/biome/bin/biome lint src tests vitest.config.ts",
    "format": "node ./node_modules/@biomejs/biome/bin/biome format --write src tests vitest.config.ts",
    "check": "node ./node_modules/@biomejs/biome/bin/biome check src tests vitest.config.ts",
    "test": "node ./node_modules/vitest/vitest.mjs run"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
