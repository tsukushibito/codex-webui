COMPOSE_PROJECT_NAME=codex-webui-tailscale-browser-check

TAILSCALE_AUTHKEY=tskey-client-your-tailnet-auth-key
TAILSCALE_HOSTNAME=codex-webui-browser-check
TAILSCALE_USERSPACE=false
TAILSCALE_EXTRA_ARGS=--accept-dns=false

BROWSER_IMAGE=selenium/standalone-chrome:latest
BROWSER_SCREEN_WIDTH=1920
BROWSER_SCREEN_HEIGHT=1080
BROWSER_SCREEN_DEPTH=24
BROWSER_SHM_SIZE=2gb
SE_VNC_NO_PASSWORD=true

NOVNC_HOST_PORT=7900
